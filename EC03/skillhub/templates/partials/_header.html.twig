<header class="header">
    <nav class="nav">
        <a href="{{ path('app_landing') }}" class="logo">SkillHub</a>
        <ul class="nav-links">
            <li><a href="{{ path('app_landing') }}" class="{% if app.request.pathInfo == '/' %}active{% endif %}">Accueil</a></li>
            <li><a href="{{ path('app_formateurs') }}" class="{% if app.request.pathInfo == '/formateurs' %}active{% endif %}">Formateurs</a></li>
            {% if app.session.get('user_id') %}
                <li><a href="{{ path('app_dashboard') }}" class="{% if app.request.pathInfo starts with '/dashboard' %}active{% endif %}">Dashboard</a></li>
                <li><a href="{{ path('app_deconnexion') }}" class="btn btn-secondary">Déconnexion</a></li>
            {% else %}
                <li><a href="{{ path('app_inscription') }}" class="{% if app.request.pathInfo == '/inscription' %}active{% endif %}">Inscription</a></li>
                <li><a href="{{ path('app_connexion') }}" class="btn btn-primary">Connexion</a></li>
            {% endif %}
        </ul>
    </nav>
</header>
