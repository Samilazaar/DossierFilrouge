{% extends 'base.html.twig' %}

{% block title %}
	{{ page_title }}
	- SkillHub
{% endblock %}

{% block body %}
	<div class="dashboard-container">
		<aside class="sidebar">
			<h2>SkillHub</h2>
			<p class="user-welcome">Bonjour,
				{{ user.prenom }}
				!</p>
			<nav class="sidebar-nav">
				<a href="{{ path('app_dashboard') }}">
					📚 Catalogue d'ateliers
				</a>
				{% if user.isFormateur() %}
					<a href="{{ path('app_dashboard_formateur') }}">
						🎓 Mes Ateliers
					</a>
				{% endif %}
				<a href="{{ path('app_dashboard_inscriptions') }}" class="active">
					✅ Mes inscriptions
				</a>
				<a href="{{ path('app_dashboard_profil') }}">
					👤 Mon Profil
				</a>
				<a href="{{ path('app_recommend_atelier') }}">
					🤖 Recommandation IA
				</a>
				<a href="{{ path('app_deconnexion') }}">
					🔐 Déconnexion
				</a>
			</nav>
		</aside>

		<main class="main-content">
			<h1>{{ page_title }}</h1>

			{% if inscriptions|length > 0 %}
				<div class="table-container">
					<table>
						<thead>
							<tr>
								<th>Atelier</th>
								<th>Formateur</th>
								<th>Date</th>
								<th>Durée</th>
								<th>Statut</th>
								<th>Action</th>
							</tr>
						</thead>
						<tbody>
							{% for inscription in inscriptions %}
								{% set atelier = inscription.getAtelier() %}
								<tr>
									<td>
										<a href="{{ path('app_atelier_detail', {'id': atelier.id}) }}">{{ atelier.titre }}</a>
									</td>
									<td>{{ atelier.getFormateurNom() }}</td>
									<td>{{ atelier.date|date('d/m/Y H:i') }}</td>
									<td>{{ atelier.duree }}</td>
									<td>
										<span class="statut-badge statut-confirme">Confirmé</span>
									</td>
									<td>
										<form method="POST" action="{{ path('app_desinscrire_atelier', {'id': atelier.id}) }}" class="inline-form">
											<button type="submit" class="btn btn-small btn-danger">Se désinscrire</button>
										</form>
									</td>
								</tr>
							{% endfor %}
						</tbody>
					</table>
				</div>
			{% else %}
				<div class="empty-state">
					<p>Vous n'êtes inscrit à aucun atelier.</p>
					<a href="{{ path('app_dashboard') }}" class="btn btn-primary">Voir les ateliers disponibles</a>
				</div>
			{% endif %}
		</main>
	</div>
{% endblock %}
