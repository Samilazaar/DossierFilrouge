{% extends 'base.html.twig' %}

{% block title %}
	{{ page_title }} - SkillHub
{% endblock %}

{% block body %}
 	<section class="hero" id="hero-section">
 		<div class="hero-background" aria-hidden="true">
 			<img 
 				src="https://images.unsplash.com/photo-1523240795612-9a054b0db644?w=1920&q=80" 
 				alt="Formation en ligne avec groupe d'étudiants apprenant ensemble dans une salle de classe moderne équipée d'ordinateurs"
 				class="hero-image"
 				loading="eager"
 			/>
 			<div class="hero-overlay"></div>
 		</div>
 		<div class="hero-content">
 			<h1>{{ page_title }}</h1>
 			<p>SkillHub est une plateforme pour apprendre de nouvelles compétences en ligne.</p>
 			<div class="hero-buttons">
 				<a href="{{ path('app_inscription') }}" class="btn btn-primary">Inscription Apprenant</a>
 				<a href="{{ path('app_formateurs') }}" class="btn btn-secondary">Voir les formateurs</a>
 			</div>
 		</div>
 	</section>

 	<section class="features" id="nos-valeurs">
 		<div class="container">
 			<h2>Nos Valeurs</h2>
 			<div class="features-grid">
 				<div class="feature-card">
 					<div class="feature-image">
 						<img 
 							src="https://images.unsplash.com/photo-1524178232363-1fb2b075b655?w=400&q=80" 
 							alt="Professeur enseignant à des étudiants dans une salle de classe moderne avec tableau interactif"
 							loading="lazy"
 						/>
 					</div>
 					<h3>Qualité Pédagogique</h3>
 					<p>Nous assurons une qualité pédagogique de haut niveau de nos formateurs</p>
 				</div>
 				<div class="feature-card">
 					<div class="feature-image">
 						<img 
 							src="https://images.unsplash.com/photo-1552664730-d307ca884978?w=400&q=80" 
 							alt="Équipe de travail collaboratif avec formateurs et apprenants discutant dans un bureau moderne"
 							loading="lazy"
 						/>
 					</div>
 					<h3>Mise en relation facile</h3>
 					<p>Nous mettons en relation facilement les apprenants avec les formateurs</p>
 				</div>
 				<div class="feature-card">
 					<div class="feature-image">
 						<img 
 							src="https://images.unsplash.com/photo-1481627834876-b7833e8f5570?w=400&q=80" 
 							alt="Bibliothèque avec étagères de livres et tablettes pour apprentissage personnalisé et formations adaptées"
 							loading="lazy"
 						/>
 					</div>
 					<h3>Formations adaptées</h3>
 					<p>Nous adaptons les formations à vos besoins</p>
 				</div>
 			</div>
 		</div>
 	</section>

 	{% if features is defined %}
 	<section class="technologies">
 		<div class="container">
 			<h2>Nos Formations</h2>
 			<div class="formations-grid">
 				<div class="formation-card">
 					<div class="formation-image">
 						<img 
 							src="https://images.unsplash.com/photo-1587620962725-abab7fe55159?w=400&q=80" 
 							alt="Développeur web créant un site internet avec du code HTML CSS JavaScript sur son ordinateur portable"
 							loading="lazy"
 						/>
 					</div>
 					<h3>Développement Web</h3>
 					<p>HTML5, CSS3, JavaScript, React, Node.js</p>
 				</div>
 				<div class="formation-card">
 					<div class="formation-image">
 						<img 
 							src="https://images.unsplash.com/photo-1561070791-2526d30994b5?w=400&q=80" 
 							alt="Designer UX concevant une interface utilisateur sur un écran tactile avec logiciel de design Figma"
 							loading="lazy"
 						/>
 					</div>
 					<h3>Design UI/UX</h3>
 					<p>Figma, Photoshop, Design Thinking, Prototypage</p>
 				</div>
 				<div class="formation-card">
 					<div class="formation-image">
 						<img 
 							src="https://images.unsplash.com/photo-1432888498266-38ffec3eaf0a?w=400&q=80" 
 							alt="Marketing digital avec analyse de données sur ordinateur pour stratégie SEO et réseaux sociaux"
 							loading="lazy"
 						/>
 					</div>
 					<h3>Marketing Digital</h3>
 					<p>SEO, Social Media, Analytics, Content Marketing</p>
 				</div>
 			</div>
 			<h2 class="tech-title">Technologies utilisées</h2>
 			<ul class="tech-list">
 				{% for feature in features %}
 				<li>{{ feature }}</li>
 				{% endfor %}
 			</ul>
 		</div>
 	</section>
 	{% endif %}
{% endblock %}
