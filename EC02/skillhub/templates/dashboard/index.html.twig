{% extends 'base.html.twig' %}

{% block title %}
	{{ page_title }} - SkillHub
{% endblock %}

{% block body %}
	<div class="dashboard-container">
		<aside class="sidebar">
			<h2>SkillHub</h2>
			<nav class="sidebar-nav">
				<a href="{{ path('app_dashboard') }}" class="{% if active_view == 'ateliers' %}active{% endif %}">
					📚 Catalogue d'ateliers
				</a>
				<a href="{{ path('app_dashboard_inscriptions') }}" class="{% if active_view == 'inscriptions' %}active{% endif %}">
					✅ Mes inscriptions
				</a>
				<a href="{{ path('app_connexion') }}">
					🔐 Déconnexion
				</a>
			</nav>
		</aside>

		<main class="main-content">
			<h1>{{ page_title }}</h1>

			<div class="ateliers-grid">
				{% for atelier in ateliers %}
					<div class="atelier-card">
						<h3>{{ atelier.titre }}</h3>
						<div class="atelier-info">
							<p>👨‍🏫 Formateur: {{ atelier.formateur }}</p>
							<p>📅 Date: {{ atelier.date }}</p>
							<p>⏱️ Durée: {{ atelier.duree }}</p>
							<p>👥 Places: {{ atelier.places }}</p>
						</div>
						<button class="btn-inscrire" {% if atelier.inscrit %}disabled{% endif %}>
							{% if atelier.inscrit %}Déjà inscrit{% else %}S'inscrire{% endif %}
						</button>
					</div>
				{% endfor %}
			</div>
		</main>
	</div>
{% endblock %}
