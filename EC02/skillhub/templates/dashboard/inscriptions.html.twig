{% extends 'base.html.twig' %}

{% block title %}
	{{ page_title }} - SkillHub
{% endblock %}

{% block body %}
	<div class="dashboard-container">
		<aside class="sidebar">
			<h2>SkillHub</h2>
			<nav class="sidebar-nav">
				<a href="{{ path('app_dashboard') }}">
					📚 Catalogue d'ateliers
				</a>
				<a href="{{ path('app_dashboard_inscriptions') }}" class="active">
					✅ Mes inscriptions
				</a>
				<a href="{{ path('app_connexion') }}">
					🔐 Déconnexion
				</a>
			</nav>
		</aside>

		<main class="main-content">
			<h1>{{ page_title }}</h1>

			<div class="table-container">
				<table>
					<thead>
						<tr>
							<th>Atelier</th>
							<th>Formateur</th>
							<th>Date</th>
							<th>Durée</th>
							<th>Statut</th>
						</tr>
					</thead>
					<tbody>
						{% for inscription in inscriptions %}
							<tr>
								<td>{{ inscription.titre }}</td>
								<td>{{ inscription.formateur }}</td>
								<td>{{ inscription.date }}</td>
								<td>{{ inscription.duree }}</td>
								<td><span class="statut-badge statut-{{ inscription.statut }}">{{ inscription.statut|capitalize }}</span></td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>
		</main>
	</div>
{% endblock %}
